{
  "manifest_version": 3,
  "name": "ArenaIQ",
  "version": "1.0.0",
  "description": "Real-time AI-powered match analysis from FlashScore",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["https://www.flashscore.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}